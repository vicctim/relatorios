# Database Configuration
DB_ROOT_PASSWORD=rootpass123
DB_NAME=relatorios
DB_USER=relatorios
DB_PASSWORD=relatorios123

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_EXPIRES_IN=7d

# Frontend Configuration
FRONTEND_URL=https://relatorio.pixfilmes.com
VITE_API_URL=/api
SHARE_URL=https://arquivos.pixfilmes.com

# File Upload Configuration
MAX_FILE_SIZE_MB=500
COMPRESSION_THRESHOLD_MB=100

# Migrations (apenas no primeiro deploy ou quando houver novas migrations)
RUN_MIGRATIONS=false

# API Key para automação (script BAT de upload)
# Gerar com: openssl rand -hex 32
API_KEY=your-api-key-here
